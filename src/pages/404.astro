---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout
	title="404 — Page Not Found | clawker"
	description="This page escaped the container. Head back to clawker, the self-hosted sandbox for AI coding agents."
>
	<main class="notfound">
		<p class="code">404</p>
		<h1>This page escaped the container.</h1>
		<p class="desc">Should have run it in clawker.</p>
		<a href="/" class="btn">Back to clawker.dev</a>
	</main>
	<Footer />
</Layout>

<style>
	.notfound {
		min-height: 60vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: 8rem 1.5rem 4rem;
	}

	.code {
		font-family: var(--font-mono);
		font-size: clamp(4rem, 12vw, 7rem);
		font-weight: 700;
		background: linear-gradient(135deg, var(--accent-bright) 0%, #fbbf24 50%, var(--accent-mid) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		line-height: 1;
		margin-bottom: 1rem;
	}

	h1 {
		font-family: var(--font-display);
		font-size: clamp(1.5rem, 4vw, 2.25rem);
		font-weight: 600;
		margin-bottom: 0.5rem;
	}

	.desc {
		color: var(--text-secondary);
		margin-bottom: 2rem;
	}

	.btn {
		display: inline-flex;
		padding: 0.75rem 1.75rem;
		border-radius: 8px;
		font-weight: 600;
		font-size: 0.9rem;
		background: var(--accent-bright);
		color: var(--bg-deep);
		transition: all 0.2s ease;
	}
	.btn:hover {
		background: var(--accent-mid);
		box-shadow: 0 0 24px var(--accent-glow);
	}
</style>
