---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import TerminalDemo from '../components/TerminalDemo.astro';
import Features from '../components/Features.astro';
import InstallBlock from '../components/InstallBlock.astro';
import Footer from '../components/Footer.astro';
import Faq from '../components/Faq.astro';
import { faq } from '../data/faq';

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faq.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: { '@type': 'Answer', text: item.answer },
	})),
};

const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: 'clawker',
	url: 'https://clawker.dev',
};

const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'clawker',
	url: 'https://clawker.dev',
	description:
		'Local, self-hosted sandbox for any AI coding agent. Run Claude Code, OpenAI Codex, OpenCode, or Pi locally in isolated Docker containers on your own machine, behind a deny-by-default egress firewall. Harness-agnostic and extensible with bundles. Free, open-source, no cloud, no subscription.',
	applicationCategory: 'DeveloperApplication',
	operatingSystem: 'macOS, Linux',
	downloadUrl: 'https://github.com/schmitthub/clawker',
	softwareHelp: { '@type': 'CreativeWork', url: 'https://docs.clawker.dev' },
	license: 'https://opensource.org/license/mit',
	offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
	keywords:
		'ai coding agent sandbox, ai agent sandbox, coding agent sandbox, claude code sandbox, run claude code in docker, codex sandbox, run openai codex in docker, opencode sandbox, pi coding agent sandbox, local ai agent sandbox, run ai coding agents locally, yolo mode, harness agnostic, ai agent harness, self-hosted, open source, no cloud, egress firewall, container isolation, network isolation, deny-by-default, devcontainer alternative, docker sandboxes alternative, parallel coding agents, git worktree, docker',
	featureList: [
		'Harness-agnostic: run Claude Code, OpenAI Codex, OpenCode, Pi, or any coding agent',
		'Bundle system: hand-roll or distribute harness setups, dev stacks, and monitoring extensions as Dockerfile template fragments and config files',
		'Per-agent isolated Docker container (agent runs unprivileged, no Linux capabilities)',
		'Deny-by-default kernel-side egress firewall (Envoy, CoreDNS, eBPF)',
		'Path- and method-scoped network rules with TLS inspection',
		'Run agents in YOLO mode (--dangerously-skip-permissions, auto-approve) safely via container isolation',
		'SSH, GPG, git, and harness credential forwarding',
		'Bind or snapshot workspace isolation modes',
		'Git worktrees for parallel coding agents',
		'Per-decision egress audit trail',
		'OpenTelemetry monitoring with Claude Code cost dashboards',
		'Control plane with mTLS-authenticated agents',
	],
	sameAs: ['https://github.com/schmitthub/clawker', 'https://docs.clawker.dev'],
};
---

<Layout
	title="Clawker — Local, Self-Hosted Sandbox for Any AI Coding Agent"
	description="Local, self-hosted sandbox for any AI coding agent. Run Claude Code, OpenAI Codex, OpenCode, or Pi locally in isolated Docker containers behind a deny-by-default egress firewall. Free, open-source, no cloud."
	canonicalUrl="https://clawker.dev/"
>
	<script type="application/ld+json" slot="head" set:html={JSON.stringify(structuredData)} />
	<script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />
	<script type="application/ld+json" slot="head" set:html={JSON.stringify(websiteSchema)} />
	<main>
	<Hero />
	<section class="threat-model">
		<div class="threat-model-container">
			<h2 class="section-title">Harness the harness</h2>
			<p class="section-desc">A padded cell for AI coding agents — how clawker's container security model compares to running a harness like Claude Code or Codex bare metal or in sandbox mode.</p>
			<blockquote class="threat-quote">
				<p>"Prompt injection can change the agent's intent, but it can't change the container's constraints."</p>
				<cite>— the <a href="https://docs.clawker.dev/threat-model" target="_blank" rel="noopener noreferrer">threat model</a></cite>
			</blockquote>
			<p class="deep-links">
				Go deeper: <a href="https://docs.clawker.dev/firewall" target="_blank" rel="noopener noreferrer">egress firewall architecture</a> ·
				<a href="https://docs.clawker.dev/architecture" target="_blank" rel="noopener noreferrer">system architecture</a> ·
				<a href="https://docs.clawker.dev/container-internals" target="_blank" rel="noopener noreferrer">container internals</a>
			</p>
		</div>
	</section>
	<TerminalDemo />
	<Features />
	<Faq />
	<InstallBlock />
	</main>
	<Footer />
</Layout>

<style>
	.threat-model {
		padding: 2rem 0 4rem;
		animation: fadeInUp 0.8s ease-out 0.2s both;
	}

	.threat-model-container {
		max-width: 880px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.section-title {
		font-family: var(--font-display);
		font-size: clamp(1.5rem, 3vw, 2rem);
		font-weight: 600;
		text-align: center;
		margin-bottom: 0.75rem;
		color: var(--text-primary);
	}

	.section-desc {
		text-align: center;
		color: var(--text-secondary);
		margin-bottom: 2.5rem;
		font-size: 0.95rem;
	}

	.threat-quote {
		margin: 2.5rem auto 0;
		max-width: 640px;
		text-align: center;
		border-left: none;
	}
	.threat-quote p {
		font-family: var(--font-display);
		font-size: clamp(1.1rem, 2.5vw, 1.4rem);
		font-weight: 500;
		color: var(--text-primary);
		line-height: 1.5;
	}
	.threat-quote cite {
		display: block;
		margin-top: 0.75rem;
		font-size: 0.85rem;
		font-style: normal;
		color: var(--text-muted);
	}
	.threat-quote cite a {
		color: var(--text-secondary);
		text-decoration: underline;
		text-underline-offset: 3px;
	}
	.threat-quote cite a:hover {
		color: var(--accent-bright);
	}

	.deep-links {
		margin-top: 1.5rem;
		text-align: center;
		font-size: 0.85rem;
		color: var(--text-muted);
	}
	.deep-links a {
		color: var(--text-secondary);
		text-decoration: underline;
		text-underline-offset: 3px;
	}
	.deep-links a:hover {
		color: var(--accent-bright);
	}
</style>
